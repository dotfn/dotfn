---
// Footer Component
---

<footer class="home-site-footer">
	<div class="footer-inner">
		<span>Nicolás Jiménez © {new Date().getFullYear()}</span>
		<span>dotfn.dev</span>
	</div>
</footer>

<style>
	.home-site-footer {
		border-top: 1px solid var(--line);
		padding: 32px 0 56px 0;
		background: var(--bg);
		transition: var(--transition-theme);
	}

	.footer-inner {
		max-width: 860px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		padding: 0 24px;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		color: var(--muted);
	}

	@media (max-width: 480px) {
		.footer-inner {
			flex-direction: column;
			gap: 8px;
			align-items: center;
			padding: 0 16px;
		}
	}
</style>
