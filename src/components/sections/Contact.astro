---
import { Mail, FileText, ArrowUpRight } from '@lucide/astro';
import Linkedin from '../icons/LinkedIn.astro';
import Github from '../icons/Github.astro';
import X from '../icons/X.astro';
import profileData from '../../data/profile.json';
import { Image } from 'astro:assets';
import contactProfile from '../../assets/contact-profile.jpg';
---

<section class="home-section" id="contacto">
	<h2 class="section-num">07 / Contacto</h2>
	<div class="contact-box card-glow">
		<div class="contact-grid">
			<div class="contact-image-col" id="contactTiltWrap">
				<Image src={contactProfile} alt="Nicolás Jiménez" class="contact-avatar" width={400} height={400} quality="high" />
			</div>
			
			<div class="contact-info-col">
				<h3 class="contact-heading">Charlemos.</h3>
				<p class="contact-text">
					Si te interesa construir productos digitales pensados para las personas, o simplemente querés intercambiar ideas sobre desarrollo, diseño o tecnología, escribime. Siempre disfruto conocer proyectos nuevos y las personas que los hacen posibles.
				</p>
				<a href={`mailto:${profileData.links.find(l => l.icon === 'em')?.url.replace('mailto:', '') || 'dotfn.contact@gmail.com'}`} class="btn-email-home" id="contactEmailLink">
					<Mail size={20} class="social-icon" /> dotfn.contact@gmail.com
				</a>
			</div>
		</div>
		
		<div class="contact-footer-links" id="contactFooter">
			<a href="https://www.linkedin.com/in/dotfn" target="_blank" rel="noopener noreferrer" data-index="0">
				<Linkedin size={14} class="social-icon" /> LinkedIn<ArrowUpRight size={14} class="arrow-icon" />
			</a>
			<a href="https://github.com/dotfn" target="_blank" rel="noopener noreferrer" data-index="1">
				<Github size={14} class="social-icon" /> GitHub<ArrowUpRight size={14} class="arrow-icon" />
			</a>
			<a href="https://x.com/dotfn_" target="_blank" rel="noopener noreferrer" data-index="2">
				<X size={14} class="social-icon" /> X (Twitter)<ArrowUpRight size={14} class="arrow-icon" />
			</a>
			<a href="/cv" data-index="3">
				<FileText size={14} class="social-icon" />C.V<ArrowUpRight size={14} class="arrow-icon" />
			</a>
		</div>
	</div>
</section>

<style>
	.home-section {
		margin-bottom: 120px;
	}

	.section-num {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.78rem;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 12px;
	}

	.contact-box {
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: 20px;
		padding: 56px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		box-shadow: var(--shadow-deep);
		transition: var(--transition-theme);
	}

	.contact-grid {
		display: grid;
		grid-template-columns: .6fr 1fr;
		gap: 48px;
		align-items: center;
		width: 100%;
		margin-bottom: 24px;
	}

	.contact-image-col {
		border-radius: 50%;
		overflow: hidden;
		border: 2px solid var(--accent);
		box-shadow: 0 8px 24px rgba(252, 213, 53, 0.15);
		background: var(--card-mid);
		transition: border-color 0.3s ease, box-shadow 0.3s ease;
		flex-shrink: 0;
		align-self: center;
		transform-style: preserve-3d;
		will-change: transform;
	}

	.contact-avatar {
		width: 100%;
		height: 100%;
		max-width:240px;
		max-height:240px;
		object-fit: cover;
		display: block;
	}

	.contact-info-col {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.contact-heading {
		font-family: var(--font-display);
		font-size: 2.8rem;
		font-weight: 800;
		color: var(--ink);
		margin-bottom: 16px;
		letter-spacing: -0.02em;
		line-height: 1.1;
	}

	.contact-text {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--ink-soft);
		max-width: 52ch;
		margin-bottom: 24px;
	}

	.btn-email-home {
		font-family: 'JetBrains Mono', monospace;
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: var(--transition);
		margin-bottom: 8px;
		word-break: break-all;
	}

	.btn-email-home:hover {
		border-bottom-color: var(--accent);
	}

	.contact-footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 24px;
		width: 100%;
		border-top: 1px solid var(--line);
		padding-top: 24px;
	}

	.contact-footer-links a {
		display: flex;
		align-items: center;
		gap: 4px;
		font-size: 0.88rem;
		color: var(--ink-soft);
		text-decoration: none;
		font-weight: 500;
		transition: var(--transition);
	}

	.contact-footer-links a:hover {
		color: var(--accent);
	}

	.social-icon {
		margin-right: 6px;
		vertical-align: middle;
		display: inline-block;
	}

	.arrow-icon {
		margin-left: 2px;
		vertical-align: middle;
		display: inline-block;
		transition: transform var(--transition);
	}

	.contact-footer-links a:hover .arrow-icon {
		transform: translate(2px, -2px);
	}

	@media (max-width: 768px) {
		.contact-box {
			padding: 40px 24px;
		}

		.contact-grid {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			gap: 24px;
			margin-bottom: 24px;
		}

		.contact-image-col {
			border-width: 1.5px;
		}

		.contact-heading {
			font-size: 2.2rem;
			margin-bottom: 12px;
		}

		.contact-text {
			font-size: 0.95rem;
			margin-bottom: 20px;
		}

		.btn-email-home {
			font-size: clamp(0.95rem, 4.5vw, 1.15rem);
			margin-bottom: 4px;
		}
		
		.contact-footer-links {
			gap: 12px 16px;
			padding-top: 16px;
		}
	}
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		// ── Stagger-reveal footer social links on scroll
		const footer = document.getElementById('contactFooter');
		if (footer) {
			const links = footer.querySelectorAll('a');
			links.forEach(a => { (a as HTMLElement).style.opacity = '0'; (a as HTMLElement).style.transform = 'translateY(10px)'; });
			const io = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						links.forEach((a, i) => {
							setTimeout(() => {
								(a as HTMLElement).style.opacity = '1';
								(a as HTMLElement).style.transform = 'translateY(0)';
								(a as HTMLElement).style.transition = 'opacity 0.4s ease, transform 0.4s ease';
							}, i * 80);
						});
						io.disconnect();
					}
				});
			}, { threshold: 0.1 });
			io.observe(footer);
		}
	});
</script>
