---
import { ArrowRight } from '@lucide/astro';
import Linkedin from '../icons/LinkedIn.astro';
import Github from '../icons/Github.astro';
import Button from '../Button.astro';
---

<section class="hero-section">
	<span class="hero-tagline">Hola, soy Nicolás</span>
	<h1 class="hero-title">Desarrollador Frontend con foco en producto.</h1>
	<p class="hero-desc">
		Transformo ideas en interfaces funcionales y experiencias intuitivas. Mi formación en Diseño Multimedial y mi interés por la ingeniería me permiten entender el producto de principio a fin, conectando el diseño UX/UI con el desarrollo de software. 
	</p>
	<div class="hero-actions">
		<Button href="/cv" variant="primary">
			Ver Curriculum 
			<ArrowRight size={16} class="btn-icon" />
		</Button>
		<div class="hero-socials">
			<a href="https://www.linkedin.com/in/dotfn" target="_blank" rel="noopener noreferrer">
				<Linkedin size={14} class="social-icon" /> LinkedIn
			</a>
			<a href="https://github.com/dotfn" target="_blank" rel="noopener noreferrer">
				<Github size={14} class="social-icon" /> GitHub
			</a>
		</div>
	</div>
</section>

<style>
	.hero-section {
		margin: 100px 0 140px 0;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.hero-tagline {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.82rem;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 16px;
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: 3rem;
		font-weight: 800;
		line-height: 1.15;
		color: var(--ink);
		letter-spacing: -0.03em;
		max-width: 18ch;
		margin-bottom: 24px;
	}

	.hero-desc {
		font-size: 1.05rem;
		line-height: 1.65;
		color: var(--ink-soft);
		max-width: 62ch;
		margin-bottom: 40px;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 32px;
	}



	.hero-socials {
		display: flex;
		gap: 20px;
	}

	.hero-socials a {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.85rem;
		color: var(--ink-soft);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: var(--transition);
	}

	.hero-socials a:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.btn-icon {
		margin-left: 6px;
		vertical-align: middle;
		display: inline-block;
	}

	.social-icon {
		margin-right: 6px;
		vertical-align: middle;
		display: inline-block;
	}

	@media (max-width: 860px) {
		.hero-title {
			font-size: 2.4rem;
		}
	}

	@media (max-width: 480px) {
		.hero-title {
			font-size: 2rem;
		}
	}
</style>
