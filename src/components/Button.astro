---
interface Props {
	href?: string;
	variant?: 'primary' | 'secondary' | 'tertiary';
	class?: string;
	id?: string;
	target?: string;
	rel?: string;
	onClick?: string;
	[key: string]: any;
}

const {
	href,
	variant = 'primary',
	class: className = '',
	id,
	target,
	rel,
	onClick,
	...rest
} = Astro.props;

const Element = href ? 'a' : 'button';
---

<Element
	href={href}
	id={id}
	class={`custom-btn btn-${variant} ${className}`}
	target={target}
	rel={rel}
	onclick={onClick}
	{...rest}
>
	<slot />
</Element>

<style>
	.custom-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-family: var(--font-display), sans-serif;
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
		border-radius: var(--radius-btn, 16px);
		transition: var(--transition);
		cursor: pointer;
		line-height: 1.2;
		border: 1px solid transparent;
		box-sizing: border-box;
	}

	/* Primary Button (Yellow black text) */
	.btn-primary {
		background: var(--accent);
		color: var(--text-dark);
		padding: 12px 24px;
		box-shadow: var(--shadow-btn);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(252, 213, 53, 0.3);
	}

	:global([data-theme="light"]) .btn-primary:hover {
		box-shadow: 0 6px 20px rgba(240, 185, 11, 0.35);
	}

	.btn-primary:active {
		transform: scale(0.98);
	}

	/* Secondary Button (surface-card border-strong) */
	.btn-secondary {
		background: var(--card-mid);
		border: 1px solid var(--line);
		color: var(--text-light);
		padding: 10px 20px;
		box-shadow: var(--shadow-btn);
	}

	.btn-secondary:hover {
		border-color: var(--accent);
		color: var(--accent);
		transform: translateY(-1px);
	}

	.btn-secondary:active {
		transform: scale(0.98);
	}

	/* Tertiary Button (text link, transparent background) */
	.btn-tertiary {
		background: transparent;
		color: var(--ink-soft);
		padding: 6px 12px;
	}

	.btn-tertiary:hover {
		color: var(--accent);
	}

	/* Accessibility */
	.custom-btn:focus-visible {
		outline: 2px solid var(--accent) !important;
		outline-offset: 4px !important;
	}
</style>
