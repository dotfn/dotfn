---
import Layout from '../../layouts/Layout.astro';
import ProfileCard from '../../components/ProfileCard.astro';
import NavHeader from '../../components/NavHeader.astro';
import Footer from '../../components/Footer.astro';
import profileData from '../../data/profile.json';

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": "https://dotfn.dev"
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Enlaces",
			"item": "https://dotfn.dev/links"
		}
	]
};
---

<Layout
	title={`Links · ${profileData.username ?? 'dotfn'}`}
	description="Encuentra todos los enlaces de Nicolás Jiménez (@dotfn), incluyendo sus redes sociales, portafolio y CV."
	schema={breadcrumbSchema}
>
	<NavHeader />

	<main class="links-wrapper">
		<ProfileCard data={profileData} />
	</main>

	<Footer />
</Layout>

<style>
	.links-wrapper {
		max-width: 600px;
		margin: 120px auto 40px;
		padding: 0 24px;
	}

	@media (max-width: 620px) {
		.links-wrapper {
			margin-top: 100px;
			padding: 0 16px;
		}
	}
</style>
